<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.CustomerSuccessPage"
             Title="Customer Success">

    <Grid RowDefinitions="Auto,*" Padding="0">
        <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="8">
            <Entry x:Name="SubjectEntry" Placeholder="Case subject" Style="{StaticResource Field}" />
            <Picker x:Name="PriorityPicker" Title="Priority">
                <Picker.Items>
                    <x:String>standard</x:String>
                    <x:String>urgent</x:String>
                    <x:String>critical</x:String>
                </Picker.Items>
            </Picker>
            <Editor x:Name="DetailEditor" Placeholder="Describe what you need from customer success" HeightRequest="100" />
            <Button Text="Open support case" Style="{StaticResource PrimaryButton}" Clicked="OnCreateClicked" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <RefreshView x:Name="RefreshHost" Refreshing="OnRefreshing">
                <CollectionView x:Name="CaseList" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="24" Spacing="8">
                            <Label Text="No support cases" Style="{StaticResource Headline}" FontSize="20" />
                            <Label Text="Cases you open with customer success will be tracked here." Style="{StaticResource Subhead}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="16,8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Subject}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding Priority}" TextColor="{StaticResource Blue}" />
                                        <Label Text="{Binding Status}" Style="{StaticResource Subhead}" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Detail}" Style="{StaticResource Subhead}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <ActivityIndicator x:Name="Busy" IsVisible="False" IsRunning="False"
                               Color="{StaticResource Blue}" VerticalOptions="Center" HorizontalOptions="Center" />

            <VerticalStackLayout x:Name="ErrorView" IsVisible="False" Padding="24" Spacing="12" VerticalOptions="Center">
                <Label Text="We couldn't load your cases" Style="{StaticResource Headline}" FontSize="20" HorizontalTextAlignment="Center" />
                <Label Text="Check your connection and try again." Style="{StaticResource Subhead}" HorizontalTextAlignment="Center" />
                <Button Text="Try again" Style="{StaticResource PrimaryButton}" Clicked="OnRetryClicked" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
