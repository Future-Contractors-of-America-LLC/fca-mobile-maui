<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.InvoicesPage"
             Title="Billing">

    <Grid>
        <RefreshView x:Name="RefreshHost" Refreshing="OnRefreshing">
            <CollectionView x:Name="InvoiceList" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8">
                        <Label Text="Billing summary" Style="{StaticResource Headline}" FontSize="22" />
                        <Label Text="Invoices and payment status from your customer portal will display here." Style="{StaticResource Subhead}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="16,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding InvoiceName}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="{Binding Amount}" TextColor="{StaticResource Blue}" />
                                    <Label Text="{Binding Status}" Style="{StaticResource Subhead}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           Color="{StaticResource Blue}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>

</ContentPage>
