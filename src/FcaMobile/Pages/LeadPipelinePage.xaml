<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Fca.Mobile.ViewModels"
             x:Class="Fca.Mobile.Pages.LeadPipelinePage"
             x:DataType="vm:LeadPipelineViewModel"
             Title="Lead Pipeline">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding InitializeCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" Style="{StaticResource OfflineBanner}" IsVisible="{Binding IsOffline}">
            <Label Text="No internet connection" TextColor="{StaticResource White}" HorizontalTextAlignment="Center" FontSize="13" />
        </Border>

        <Label Grid.Row="1"
               Style="{StaticResource ErrorLabel}"
               Padding="16,8,16,0"
               IsVisible="{Binding HasError}"
               Text="{Binding ErrorMessage}" />

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Leads}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8">
                        <Label Text="No leads yet" Style="{StaticResource Headline}" FontSize="22" />
                        <Label Text="New opportunities from your website, referrals, and field teams will appear here." Style="{StaticResource Subhead}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BidRecord"
                                  xmlns:models="clr-namespace:Fca.Mobile.Models;assembly=FcaMobile.Core">
                        <Border Style="{StaticResource Card}" Margin="16,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ProjectName}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                                <Label Text="{Binding Company}" Style="{StaticResource Subhead}" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="{Binding Status}" TextColor="{StaticResource Blue}" />
                                    <Label Text="{Binding Value, StringFormat='${0:N0}'}" TextColor="{StaticResource Muted}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.RowSpan="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Blue}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
