<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.PlanRoomPage"
             Title="Plan Room">

    <RefreshView x:Name="RefreshHost" Refreshing="OnRefreshing">
        <CollectionView x:Name="DocList" SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="8">
                    <Label Text="Plan room" Style="{StaticResource Headline}" FontSize="22" />
                    <Label Text="Drawings, specs, and submittals shared with your team will be listed here." Style="{StaticResource Subhead}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="16,8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                            <Label Text="{Binding Category}" TextColor="{StaticResource Blue}" />
                            <Label Text="{Binding Status}" Style="{StaticResource Subhead}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>

</ContentPage>
