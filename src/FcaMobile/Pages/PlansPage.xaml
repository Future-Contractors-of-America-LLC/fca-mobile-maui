<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.PlansPage"
             Title="Plans">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Plans built for contractor growth" Style="{StaticResource Headline}" />
            <Label Text="Every tier includes lead management, job tracking, plan room access, billing visibility, and workforce training." Style="{StaticResource Subhead}" />

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Startup — $99/mo" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                    <Label Text="For emerging contractors winning their first commercial accounts." Style="{StaticResource Subhead}" />
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Pilot — $2,500" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                    <Label Text="White-glove onboarding for teams ready to standardize bids, jobs, and field communication." Style="{StaticResource Subhead}" />
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Enterprise — custom" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                    <Label Text="Multi-office rollouts with advanced controls, integrations, and dedicated success coverage." Style="{StaticResource Subhead}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Get Started" Style="{StaticResource PrimaryButton}" Clicked="OnGetStartedClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
