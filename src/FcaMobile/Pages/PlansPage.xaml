<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.PlansPage"
             Title="Plans">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Image Source="fca_hex_mark.png" HeightRequest="72" WidthRequest="72" HorizontalOptions="Start" />
            <Label Text="Plans built for contractor growth" Style="{StaticResource Headline}" />
            <Label Text="Every tier includes lead management, job tracking, plan room access, billing visibility, and workforce training." Style="{StaticResource Subhead}" />

            <CollectionView x:Name="PlanCards" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                                <Label Text="{Binding Price}" FontAttributes="Bold" TextColor="{StaticResource Gold}" />
                                <Label Text="{Binding Detail}" Style="{StaticResource Subhead}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Get Started" Style="{StaticResource PrimaryButton}" Clicked="OnGetStartedClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
