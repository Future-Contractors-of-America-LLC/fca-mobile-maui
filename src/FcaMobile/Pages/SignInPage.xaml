<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Fca.Mobile.ViewModels"
             x:Class="Fca.Mobile.Pages.SignInPage"
             x:DataType="vm:SignInViewModel"
             Title="Sign In">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding InitializeCommand}" />
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Welcome back" Style="{StaticResource Headline}" />
            <Label Text="Sign in to your FCA Contractor Command workspace." Style="{StaticResource Subhead}" />

            <Entry Placeholder="Work email"
                   Keyboard="Email"
                   Style="{StaticResource Field}"
                   Text="{Binding Email}"
                   ReturnType="Next"
                   SemanticProperties.Description="Work email address" />
            <Entry Placeholder="Password"
                   IsPassword="True"
                   Style="{StaticResource Field}"
                   Text="{Binding Password}"
                   ReturnType="Done"
                   SemanticProperties.Description="Account password" />

            <Border Style="{StaticResource OfflineBanner}" IsVisible="{Binding IsOffline}">
                <Label Text="No internet connection"
                       TextColor="{StaticResource White}"
                       HorizontalTextAlignment="Center"
                       FontSize="13" />
            </Border>

            <Label Style="{StaticResource ErrorLabel}" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Blue}"
                               HorizontalOptions="Center" />

            <Button Text="Sign In"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SignInCommand}" />
            <Button Text="Need an account? Get started"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GetStartedCommand}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
