<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fca.Mobile.Pages.SignInPage"
             Title="Sign In">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Welcome back" Style="{StaticResource Headline}" />
            <Label Text="Sign in to your FCA Contractor Command workspace." Style="{StaticResource Subhead}" />

            <Entry x:Name="EmailEntry"
                   AutomationId="SignInEmailEntry"
                   Placeholder="Work email"
                   Keyboard="Email"
                   Style="{StaticResource Field}"
                   SemanticProperties.Description="Work email address" />
            <Entry x:Name="PasswordEntry"
                   AutomationId="SignInPasswordEntry"
                   Placeholder="Password"
                   IsPassword="True"
                   Style="{StaticResource Field}"
                   SemanticProperties.Description="Password" />

            <Label x:Name="StatusLabel"
                   TextColor="#DC2626"
                   IsVisible="False"
                   SemanticProperties.Description="Sign in status" />

            <ActivityIndicator x:Name="BusyIndicator" IsVisible="False" IsRunning="False" />

            <Button x:Name="SignInButton"
                    Text="Sign In"
                    AutomationId="SignInSubmitButton"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="OnSignInClicked" />
            <Button x:Name="GetStartedButton"
                    Text="Need an account? Get started"
                    AutomationId="SignInGetStartedButton"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnGetStartedClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
