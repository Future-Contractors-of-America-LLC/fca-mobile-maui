<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Fca.Mobile.ViewModels"
             x:Class="Fca.Mobile.Pages.TrainingPage"
             x:DataType="vm:TrainingViewModel"
             Title="Training">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding InitializeCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" Style="{StaticResource OfflineBanner}" IsVisible="{Binding IsOffline}">
            <Label Text="No internet connection" TextColor="{StaticResource White}" HorizontalTextAlignment="Center" FontSize="13" />
        </Border>
        <Label Grid.Row="1" Style="{StaticResource ErrorLabel}" Padding="16,8,16,0" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />
        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Programs}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8">
                        <Label Text="Workforce training catalog" Style="{StaticResource Headline}" FontSize="22" />
                        <Label Text="Safety, trade credentials, and supervisor programs will appear as your Academy catalog is assigned." Style="{StaticResource Subhead}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AcademyProgram"
                                  xmlns:models="clr-namespace:Fca.Mobile.Models;assembly=FcaMobile.Core">
                        <Border Style="{StaticResource Card}" Margin="16,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource Navy}" />
                                <Label Text="{Binding Level}" TextColor="{StaticResource Blue}" />
                                <Label Text="{Binding Status}" Style="{StaticResource Subhead}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
        <ActivityIndicator Grid.RowSpan="3" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Blue}" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>

</ContentPage>
